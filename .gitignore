# --- Node / JS package directories ---
node_modules/
landing-page/node_modules/

# --- Package manager logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Build outputs ---
build/
web-build/



# --- Expo / React Native caches ---
.expo/
.expo-shared/
.metro-cache/

# --- Platform specific (if using prebuild) ---
android/
ios/

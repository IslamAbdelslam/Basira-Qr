ios/Pods/

# --- Caches / tooling ---
.cache/
.parcel-cache/
.turbo/
.vite/
.eslintcache

# --- Coverage ---
coverage/
.nyc_output/

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- Editor / IDE ---
.vscode/
.idea/
*.iml
*.code-workspace

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Misc ---
*.log
*.tmp
.tmp/
.temp/
logs/
*.orig

# --- Landing page specific ---
landing-page/.vite/
